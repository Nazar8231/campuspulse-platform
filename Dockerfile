# Використовуємо офіційний образ Node.js версії 20
FROM node:20

# Створюємо робочу директорію в контейнері
WORKDIR /app

# Копіюємо файли з package.json та package-lock.json (якщо є)
COPY package*.json ./

# Примусово встановлюємо залежності
RUN npm install

# Копіюємо ВСІ файли проєкту в контейнер
COPY . .

# Вказуємо порт, який буде використовувати додаток
EXPOSE 10000

# Команда для запуску сервера
CMD ["node", "server.js"]
